# BagStore production deployment environment template
# GitHub Actions generates this file on the AWS server during deployment.
# Keep real values in GitHub Secrets/Variables, not in this repository.

# Runtime
NODE_ENV=production
APP_PROTOCOL=http
AWS_HOST=203.0.113.10
DOMAIN_NAME=
APP_PORT=80
SERVER_PORT=5000

# Derived by the deployment workflow from APP_PROTOCOL, DOMAIN_NAME/AWS_HOST,
# APP_PORT, and SERVER_PORT. Keep these here so docker compose can run locally
# against a copied deployment env when needed.
FRONTEND_URL=http://203.0.113.10
BACKEND_URL=http://203.0.113.10:5000
PUBLIC_API_URL=http://203.0.113.10/api
ALLOWED_ORIGINS=http://203.0.113.10

# Database and app secrets
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/bagstore?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_production_secret

# Docker image base and tag
# Production images resolve to:
#   ${DOCKER_IMAGE}-backend:${DOCKER_TAG}
#   ${DOCKER_IMAGE}-frontend:${DOCKER_TAG}
DOCKER_IMAGE=your-dockerhub-username/bagstore
DOCKER_TAG=latest
