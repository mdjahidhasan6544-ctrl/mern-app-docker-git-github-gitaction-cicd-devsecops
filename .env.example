# BagStore local development environment
# Copy this file to .env for local development only.
# Never commit real .env files or production secrets.

# Runtime
NODE_ENV=development
APP_PROTOCOL=http
AWS_HOST=localhost
DOMAIN_NAME=
APP_PORT=3000
SERVER_PORT=5000

# Derived application URLs for local development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
PUBLIC_API_URL=http://localhost:5000/api
ALLOWED_ORIGINS=http://localhost:3000

# Database and app secrets
MONGODB_URI=mongodb://localhost:27017/bagstore
JWT_SECRET=replace_with_a_long_random_local_secret

# Docker image base and tag
# Production images resolve to:
#   ${DOCKER_IMAGE}-backend:${DOCKER_TAG}
#   ${DOCKER_IMAGE}-frontend:${DOCKER_TAG}
DOCKER_IMAGE=your-dockerhub-username/bagstore
DOCKER_TAG=local
